@page "/organization"
@using fencemark.Client.Features.Auth
@using fencemark.Client.Features.Organization
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize]
@inject OrganizationApiClient OrgApi
@inject AuthApiClient AuthApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Organization Dashboard</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="m-0">Organization Members</h2>
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Settings"
                               Href="/settings/organization">
                        Settings
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="ShowInviteModal">
                        Invite Member
                    </MudButton>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (members == null || !members.Any())
            {
                <div class="alert alert-info">
                    No members found. Invite users to your organization.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Joined</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in members)
                            {
                                <tr>
                                    <td>@member.Email</td>
                                    <td>
                                        @if (member.Role == "Owner")
                                        {
                                            <span class="badge bg-primary">@member.Role</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@member.Role</span>
                                        }
                                    </td>
                                    <td>
                                        @if (member.IsGuest)
                                        {
                                            <span class="badge bg-warning">Guest</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>@member.JoinedAt.ToShortDateString()</td>
                                    <td>
                                        @if (member.Role != "Owner")
                                        {
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button class="btn btn-outline-primary" @onclick="() => ShowRoleModal(member)">
                                                    Change Role
                                                </button>
                                                <button class="btn btn-outline-danger" @onclick="() => RemoveMemberAsync(member.UserId)">
                                                    Remove
                                                </button>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success mt-3" role="alert">
            @successMessage
        </div>
    }
</div>

<!-- Invite Member Modal -->
<MudOverlay Visible="@showInviteModal" DarkBackground="true" ZIndex="1300" LockScroll="true">
    <MudPaper Class="pa-4 ma-4" Style="max-width: 500px; width: 100%;">
        <MudText Typo="Typo.h6" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
            Invite Member
        </MudText>

        <EditForm Model="@inviteModel" OnValidSubmit="@HandleInviteAsync">
            <DataAnnotationsValidator />

            <MudTextField Label="Email"
                          @bind-Value="inviteModel.Email"
                          Required="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="InputType.Email"
                          Class="mb-3" />
            <ValidationMessage For="@(() => inviteModel.Email)" />

            <MudSelect Label="Role"
                       @bind-Value="inviteModel.Role"
                       Required="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("Member")">Member</MudSelectItem>
                <MudSelectItem Value="@("Billing")">Billing</MudSelectItem>
                <MudSelectItem Value="@("ReadOnly")">Read Only</MudSelectItem>
            </MudSelect>
            <ValidationMessage For="@(() => inviteModel.Role)" />

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="HideInviteModal">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           ButtonType="ButtonType.Submit"
                           Disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Send Invitation
                </MudButton>
            </div>
        </EditForm>
    </MudPaper>
</MudOverlay>

<!-- Change Role Modal -->
<MudOverlay Visible="@showRoleModal" DarkBackground="true" ZIndex="1300" LockScroll="true">
    @if (selectedMember != null)
    {
        <MudPaper Class="pa-4 ma-4" Style="max-width: 500px; width: 100%;">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="mr-2" />
                Change Role for @selectedMember.Email
            </MudText>

            <EditForm Model="@roleModel" OnValidSubmit="@HandleRoleChangeAsync">
                <MudSelect Label="New Role"
                           @bind-Value="roleModel.Role"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                    <MudSelectItem Value="@("Member")">Member</MudSelectItem>
                    <MudSelectItem Value="@("Billing")">Billing</MudSelectItem>
                    <MudSelectItem Value="@("ReadOnly")">Read Only</MudSelectItem>
                </MudSelect>

                <div class="d-flex justify-end gap-2 mt-4">
                    <MudButton Variant="Variant.Text" OnClick="HideRoleModal">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               ButtonType="ButtonType.Submit"
                               Disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Update Role
                    </MudButton>
                </div>
            </EditForm>
        </MudPaper>
    }
</MudOverlay>

@code {
    private List<OrganizationMemberResponse>? members;
    private string? organizationId;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;
    private bool showInviteModal;
    private bool showRoleModal;
    private OrganizationMemberResponse? selectedMember;
    private InviteModel inviteModel = new();
    private RoleModel roleModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMembersAsync();
    }

    private async Task LoadMembersAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Get current user to get organization ID
            var currentUser = await AuthApi.GetCurrentUserAsync();
            if (currentUser != null)
            {
                organizationId = currentUser.OrganizationId;

                if (!string.IsNullOrEmpty(organizationId))
                {
                    members = (await OrgApi.GetMembersAsync(organizationId))?.ToList();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load members: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowInviteModal()
    {
        inviteModel = new InviteModel();
        showInviteModal = true;
    }

    private void HideInviteModal()
    {
        showInviteModal = false;
        inviteModel = new InviteModel();
    }

    private void ShowRoleModal(OrganizationMemberResponse member)
    {
        selectedMember = member;
        roleModel = new RoleModel { Role = member.Role };
        showRoleModal = true;
    }

    private void HideRoleModal()
    {
        showRoleModal = false;
        selectedMember = null;
        roleModel = new RoleModel();
    }

    private async Task HandleInviteAsync()
    {
        if (string.IsNullOrEmpty(organizationId)) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new InviteUserRequest(inviteModel.Email, inviteModel.Role);
            var response = await OrgApi.InviteUserAsync(organizationId, request);

            if (response?.Success == true)
            {
                successMessage = response.Message ?? "Invitation sent successfully";
                HideInviteModal();
                await LoadMembersAsync();
            }
            else
            {
                errorMessage = response?.Message ?? "Failed to send invitation";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task HandleRoleChangeAsync()
    {
        if (string.IsNullOrEmpty(organizationId) || selectedMember == null) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var request = new UpdateRoleRequest(selectedMember.UserId, roleModel.Role);
            var success = await OrgApi.UpdateRoleAsync(organizationId, request);

            if (success)
            {
                successMessage = "Role updated successfully";
                HideRoleModal();
                await LoadMembersAsync();
            }
            else
            {
                errorMessage = "Failed to update role";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task RemoveMemberAsync(string userId)
    {
        if (string.IsNullOrEmpty(organizationId)) return;

        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to remove this member?"))
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            var success = await OrgApi.RemoveMemberAsync(organizationId, userId);

            if (success)
            {
                successMessage = "Member removed successfully";
                await LoadMembersAsync();
            }
            else
            {
                errorMessage = "Failed to remove member";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
    }

    private class InviteModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string Role { get; set; } = "Member";
    }

    private class RoleModel
    {
        public string Role { get; set; } = "Member";
    }
}
