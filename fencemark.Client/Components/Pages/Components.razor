@page "/components"
@using ComponentDto = fencemark.Client.Features.Components.ComponentDto
@using ComponentApiClient = fencemark.Client.Features.Components.ComponentApiClient
@using Microsoft.AspNetCore.Authorization
@using fencemark.Client.Components.Shared
@inject ComponentApiClient ComponentClient
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Components - Fencemark</PageTitle>

<PageHeader Title="Components & Pricing"
            Icon="@Icons.Material.Filled.Inventory2"
            Subtitle="Manage your component catalog and pricing">
    <Actions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateModal">
            Add Component
        </MudButton>
    </Actions>
</PageHeader>

<div class="container-fluid">

    @if (isLoading)
    {
        <LoadingState Message="Loading components..." />
    }
    else if (components == null || !components.Any())
    {
        <EmptyState Icon="@Icons.Material.Filled.Inventory2"
                    Title="No components found"
                    Message="Create your first component to get started!">
            <Action>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="ShowCreateModal">
                    Add Your First Component
                </MudButton>
            </Action>
        </EmptyState>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Material</th>
                        <th>Dimensions</th>
                        <th>Unit</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var component in components)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-primary">@component.Category</span>
                            </td>
                            <td>
                                <strong>@component.Name</strong>
                                @if (!string.IsNullOrEmpty(component.Description))
                                {
                                    <br /><small class="text-muted">@component.Description</small>
                                }
                            </td>
                            <td>@component.Sku</td>
                            <td>@component.Material</td>
                            <td>@component.Dimensions</td>
                            <td>@component.UnitOfMeasure</td>
                            <td class="price-cell">$@component.UnitPrice.ToString("F2")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditComponent(component)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteComponent(component)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <MudOverlay Visible="@showModal" DarkBackground="true" ZIndex="1300" LockScroll="true">
        <MudPaper Class="pa-4 ma-4" Style="max-width: 800px; width: 100%; max-height: calc(100vh - 100px); overflow-y: auto;">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-2" />
                @(editingComponent?.Id == null ? "Create" : "Edit") Component
            </MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }

            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudTextField Label="Name"
                                  @bind-Value="editingComponent.Name"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g., 6x6 Pressure Treated Post" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField Label="SKU"
                                  @bind-Value="editingComponent.Sku"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g., PT-POST-6X6" />
                </MudItem>
            </MudGrid>

            <MudTextField Label="Description"
                          @bind-Value="editingComponent.Description"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="2"
                          Class="mt-3"
                          Placeholder="Additional details about this component" />

            <MudGrid Class="mt-3">
                <MudItem xs="12" md="6">
                    <MudSelect Label="Category"
                               @bind-Value="editingComponent.Category"
                               Required="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("")">Select category...</MudSelectItem>
                        <MudSelectItem Value="@("Post")">Post</MudSelectItem>
                        <MudSelectItem Value="@("Rail")">Rail</MudSelectItem>
                        <MudSelectItem Value="@("Panel")">Panel</MudSelectItem>
                        <MudSelectItem Value="@("Picket")">Picket</MudSelectItem>
                        <MudSelectItem Value="@("Hardware")">Hardware</MudSelectItem>
                        <MudSelectItem Value="@("Gate Hardware")">Gate Hardware</MudSelectItem>
                        <MudSelectItem Value="@("Fastener")">Fastener</MudSelectItem>
                        <MudSelectItem Value="@("Concrete")">Concrete</MudSelectItem>
                        <MudSelectItem Value="@("Stain/Sealer")">Stain/Sealer</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Material"
                                  @bind-Value="editingComponent.Material"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g., Pressure Treated Pine" />
                </MudItem>
            </MudGrid>

            <MudGrid Class="mt-3">
                <MudItem xs="12" md="4">
                    <MudTextField Label="Dimensions"
                                  @bind-Value="editingComponent.Dimensions"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="e.g., 6x6x8" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect Label="Unit of Measure"
                               @bind-Value="editingComponent.UnitOfMeasure"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("Each")">Each</MudSelectItem>
                        <MudSelectItem Value="@("Linear Metre")">Linear Metre</MudSelectItem>
                        <MudSelectItem Value="@("Board Metre")">Board Metre</MudSelectItem>
                        <MudSelectItem Value="@("Square Metre")">Square Metre</MudSelectItem>
                        <MudSelectItem Value="@("Litre")">Litre</MudSelectItem>
                        <MudSelectItem Value="@("Bag")">Bag</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField Label="Unit Price"
                                     @bind-Value="editingComponent.UnitPrice"
                                     T="decimal"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0m"
                                     Step="0.01m"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                </MudItem>
            </MudGrid>

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" OnClick="CloseModal">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveComponent"
                           Disabled="@isSaving">
                    @if (isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Save
                </MudButton>
            </div>
        </MudPaper>
    </MudOverlay>
}

@code {
    private List<ComponentDto>? components;
    private ComponentDto editingComponent = new() { Name = "", OrganizationId = "", Category = "" };
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadComponents();
    }

    private async Task LoadComponents()
    {
        isLoading = true;
        try
        {
            var result = await ComponentClient.GetAllAsync();
            components = result?.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading components: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        editingComponent = new ComponentDto { Name = "", OrganizationId = "", Category = "" };
        errorMessage = null;
        showModal = true;
    }

    private void EditComponent(ComponentDto component)
    {
        editingComponent = new ComponentDto
        {
            Id = component.Id,
            Name = component.Name,
            Description = component.Description,
            Sku = component.Sku,
            Category = component.Category,
            UnitOfMeasure = component.UnitOfMeasure,
            UnitPrice = component.UnitPrice,
            Material = component.Material,
            Dimensions = component.Dimensions,
            OrganizationId = component.OrganizationId
        };
        errorMessage = null;
        showModal = true;
    }

    private async Task SaveComponent()
    {
        if (string.IsNullOrWhiteSpace(editingComponent.Name) || string.IsNullOrWhiteSpace(editingComponent.Category))
        {
            errorMessage = "Name and Category are required";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            if (string.IsNullOrEmpty(editingComponent.Id))
            {
                await ComponentClient.CreateAsync(editingComponent);
            }
            else
            {
                await ComponentClient.UpdateAsync(editingComponent.Id, editingComponent);
            }

            await LoadComponents();
            CloseModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving component: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteComponent(ComponentDto component)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{component.Name}'?"))
            return;

        try
        {
            await ComponentClient.DeleteAsync(component.Id);
            await LoadComponents();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting component: {ex.Message}";
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingComponent = new() { Name = "", OrganizationId = "", Category = "" };
        errorMessage = null;
    }
}
