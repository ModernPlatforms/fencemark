@page "/Error"
@using System.Diagnostics
@inject IConfiguration Configuration

<PageTitle>Error</PageTitle>

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@requestId</code>
    </p>
}

@if (IsDevelopment)
{
    <h3>Development Information</h3>
    <p>
        This application is running in <strong>Development</strong> mode. More detailed error information will be logged for troubleshooting.
    </p>
}
else
{
    <p>
        Please try again, or contact support if the problem persists.
    </p>
}

@code{
    private string? requestId;
    private bool IsDevelopment;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id;
        IsDevelopment = Configuration.GetValue<bool>("IsDevelopment", false);
    }
}
