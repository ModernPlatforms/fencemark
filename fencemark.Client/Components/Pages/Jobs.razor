@page "/jobs"
@using fencemark.Client.Features.Jobs
@using Microsoft.AspNetCore.Authorization
@inject JobApiClient JobClient
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@attribute [Authorize]

<PageTitle>Jobs - Fencemark</PageTitle>

<div class="modern-container">
    <div class="flex flex-row flex-wrap gap-4 mb-8 items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold" style="margin-bottom: 0.25rem;">Jobs</h1>
            <p class="text-muted">Manage all your fencing projects</p>
        </div>
        <button class="modern-btn modern-btn-primary gap-2" @onclick="ShowCreateModal">
            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
            New Job
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center" style="padding: 3rem 0;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading jobs...</p>
        </div>
    }
    else if (jobs == null || !jobs.Any())
    {
        <div class="modern-card" style="padding: 2rem; text-align: center;">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Info" Class="mb-3" />
            <p class="text-muted">No jobs found. Create your first job to get started!</p>
        </div>
    }
    else
    {
        <div class="modern-grid modern-grid-cols-3">
            @foreach (var job in jobs)
            {
                <div class="modern-job-card">
                    <div class="modern-job-card-header">
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="modern-card-title" style="margin: 0;">@job.Name</h3>
                            <span class="modern-badge @GetStatusBadgeClass(job.Status)">@GetStatusDisplayName(job.Status)</span>
                        </div>
                        <p class="modern-card-description" style="margin: 0;">@job.CustomerName</p>
                    </div>
                    
                    <div class="modern-job-card-body">
                        <div style="margin-bottom: 1rem;">
                            @if (!string.IsNullOrEmpty(job.CustomerEmail))
                            {
                                <div class="modern-info-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                                    <span>@job.CustomerEmail</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(job.CustomerPhone))
                            {
                                <div class="modern-info-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                    <span>@job.CustomerPhone</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(job.InstallationAddress))
                            {
                                <div class="modern-info-item">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                    <span>@job.InstallationAddress</span>
                                </div>
                            }
                            <div class="modern-info-item" style="margin-top: 0.75rem;">
                                <MudIcon Icon="@Icons.Material.Filled.Straighten" Size="Size.Small" />
                                <span><strong>@job.TotalLinearMetres m</strong> total</span>
                            </div>
                        </div>
                        
                        <div style="margin-top: 1rem; padding-top: 1rem;" class="border-t">
                            <div class="flex justify-between mb-2 text-sm">
                                <span class="text-muted">Materials:</span>
                                <span>$@job.MaterialsCost.ToString("F2")</span>
                            </div>
                            <div class="flex justify-between mb-2 text-sm">
                                <span class="text-muted">Labor:</span>
                                <span>$@job.LaborCost.ToString("F2")</span>
                            </div>
                            <div class="flex justify-between font-bold mt-3">
                                <span>Total:</span>
                                <span class="text-success">$@job.TotalCost.ToString("F2")</span>
                            </div>
                        </div>
                        
                        @if (job.TotalLinearMetres > 0)
                        {
                            var progress = CalculateProgress(job);
                            <div style="margin-top: 1rem;">
                                <div class="flex justify-between mb-1 text-sm">
                                    <span class="text-muted">Progress</span>
                                    <span class="font-semibold">@progress%</span>
                                </div>
                                <div class="modern-progress">
                                    <div class="modern-progress-bar" style="width: @(progress)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <div class="modern-job-card-footer">
                        <button class="modern-btn modern-btn-primary w-full mb-2" @onclick="() => OpenDrawing(job.Id)">
                            <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" />
                            Open Drawing
                        </button>
                        <div class="flex gap-2">
                            <button class="modern-btn modern-btn-outline" style="flex: 1;" @onclick="() => EditJob(job)">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                Edit
                            </button>
                            <button class="modern-btn modern-btn-danger" style="flex: 1;" @onclick="() => DeleteJob(job)">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<MudOverlay Visible="@showModal" DarkBackground="true" ZIndex="1300" LockScroll="true">
    <MudPaper Class="pa-4 ma-4" Style="max-width: 800px; width: 100%; max-height: calc(100vh - 100px); overflow-y: auto;">
        <MudText Typo="Typo.h6" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Work" Class="mr-2" />
            @(editingJob?.Id == null ? "Create" : "Edit") Job
        </MudText>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Job Name"
                              @bind-Value="editingJob.Name"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="e.g., Smith Backyard Fence" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect Label="Status"
                           @bind-Value="editingJob.Status"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (JobStatusDto status in Enum.GetValues(typeof(JobStatusDto)))
                    {
                        <MudSelectItem Value="@status">@GetStatusDisplayName(status)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Customer Information</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Customer Name"
                              @bind-Value="editingJob.CustomerName"
                              Required="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Customer Email"
                              @bind-Value="editingJob.CustomerEmail"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="InputType.Email" />
            </MudItem>
        </MudGrid>

        <MudGrid Class="mt-2">
            <MudItem xs="12" md="6">
                <MudTextField Label="Customer Phone"
                              @bind-Value="editingJob.CustomerPhone"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="InputType.Telephone" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Installation Address"
                              @bind-Value="editingJob.InstallationAddress"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Job Details</MudText>
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudNumericField Label="Total Linear Metres"
                                 @bind-Value="editingJob.TotalLinearMetres"
                                 T="decimal"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0m"
                                 Step="0.1m" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField Label="Materials Cost"
                                 @bind-Value="editingJob.MaterialsCost"
                                 T="decimal"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0m"
                                 Step="0.01m"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField Label="Labor Cost"
                                 @bind-Value="editingJob.LaborCost"
                                 T="decimal"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0m"
                                 Step="0.01m"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField Label="Total Cost"
                                 @bind-Value="editingJob.TotalCost"
                                 T="decimal"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0m"
                                 Step="0.01m"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
            </MudItem>
        </MudGrid>

        <MudGrid Class="mt-2">
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Estimated Start Date"
                               @bind-Date="editingJob.EstimatedStartDate"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Estimated Completion Date"
                               @bind-Date="editingJob.EstimatedCompletionDate"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <MudTextField Label="Notes"
                      @bind-Value="editingJob.Notes"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="3"
                      Class="mt-3"
                      Placeholder="Additional notes about the job" />

        <div class="d-flex justify-end gap-2 mt-4">
            <MudButton Variant="Variant.Text" OnClick="CloseModal">Cancel</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveJob"
                       Disabled="@isSaving">
                @if (isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save
            </MudButton>
        </div>
    </MudPaper>
</MudOverlay>

@code {
    private List<JobDto>? jobs;
    private JobDto editingJob = new() { Name = "", CustomerName = "", OrganizationId = "" };
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showModal = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
    }

    private async Task LoadJobs()
    {
        isLoading = true;
        try
        {
            var result = await JobClient.GetAllAsync();
            jobs = result?.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading jobs: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        editingJob = new JobDto { Name = "", CustomerName = "", OrganizationId = "" };
        errorMessage = null;
        showModal = true;
    }

    private void EditJob(JobDto job)
    {
        editingJob = new JobDto
        {
            Id = job.Id,
            Name = job.Name,
            CustomerName = job.CustomerName,
            CustomerEmail = job.CustomerEmail,
            CustomerPhone = job.CustomerPhone,
            InstallationAddress = job.InstallationAddress,
            Status = job.Status,
            TotalLinearMetres = job.TotalLinearMetres,
            LaborCost = job.LaborCost,
            MaterialsCost = job.MaterialsCost,
            TotalCost = job.TotalCost,
            Notes = job.Notes,
            EstimatedStartDate = job.EstimatedStartDate,
            EstimatedCompletionDate = job.EstimatedCompletionDate,
            OrganizationId = job.OrganizationId
        };
        errorMessage = null;
        showModal = true;
    }

    private async Task SaveJob()
    {
        if (string.IsNullOrWhiteSpace(editingJob.Name) || string.IsNullOrWhiteSpace(editingJob.CustomerName))
        {
            errorMessage = "Job Name and Customer Name are required";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            if (string.IsNullOrEmpty(editingJob.Id))
            {
                await JobClient.CreateAsync(editingJob);
            }
            else
            {
                await JobClient.UpdateAsync(editingJob.Id, editingJob);
            }

            await LoadJobs();
            CloseModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving job: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteJob(JobDto job)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{job.Name}'?"))
            return;

        try
        {
            await JobClient.DeleteAsync(job.Id);
            await LoadJobs();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting job: {ex.Message}";
        }
    }

    private void CloseModal()
    {
        showModal = false;
        editingJob = new() { Name = "", CustomerName = "", OrganizationId = "" };
        errorMessage = null;
    }

    private void OpenDrawing(string jobId)
    {
        Navigation.NavigateTo($"/jobs/{jobId}/drawing");
    }

    private string GetStatusBadgeClass(JobStatusDto status) => status switch
    {
        JobStatusDto.Draft => "modern-badge-secondary",
        JobStatusDto.Quoted => "modern-badge-info",
        JobStatusDto.Approved => "modern-badge-info",
        JobStatusDto.InProgress => "modern-badge-warning",
        JobStatusDto.Completed => "modern-badge-success",
        JobStatusDto.Cancelled => "modern-badge-error",
        _ => "modern-badge-secondary"
    };
    
    private string GetStatusDisplayName(JobStatusDto status) => status switch
    {
        JobStatusDto.Draft => "Draft",
        JobStatusDto.Quoted => "Quoted",
        JobStatusDto.Approved => "Approved",
        JobStatusDto.InProgress => "In Progress",
        JobStatusDto.Completed => "Completed",
        JobStatusDto.Cancelled => "Cancelled",
        _ => status.ToString()
    };
    
    private int CalculateProgress(JobDto job)
    {
        return job.Status switch
        {
            JobStatusDto.Draft => 10,
            JobStatusDto.Quoted => 25,
            JobStatusDto.Approved => 40,
            JobStatusDto.InProgress => 65,
            JobStatusDto.Completed => 100,
            JobStatusDto.Cancelled => 0,
            _ => 0
        };
    }
}
