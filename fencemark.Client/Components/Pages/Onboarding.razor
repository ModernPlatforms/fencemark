@page "/onboarding"
@using fencemark.Client.Features.Auth
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@implements IDisposable
@inject HttpClient ApiClient
@inject NavigationManager Navigation
@inject AuthApiClient AuthApi

<PageTitle>Organization Setup</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create Your Organization</h4>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Setting up your organization...</p>
                        </div>
                    }
                    else if (hasOrganization)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <svg class="text-success" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </div>
                            <h5 class="mb-3 text-success">Organization Ready!</h5>
                            <p class="mb-4 text-muted">You already have an organization set up. Ready to get started?</p>
                            <button class="btn btn-primary btn-lg" @onclick="@(() => Navigation.NavigateTo("/jobs"))">
                                Go to Jobs
                            </button>
                            <p class="mt-3 text-muted small">Redirecting in @redirectCountdown seconds...</p>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@model" OnValidSubmit="@HandleSubmitAsync">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="orgName" class="form-label">Organization Name <span class="text-danger">*</span></label>
                                <InputText id="orgName" 
                                          @bind-Value="model.OrganizationName" 
                                          class="form-control" 
                                          placeholder="e.g., Acme Fencing Co." />
                                <ValidationMessage For="@(() => model.OrganizationName)" />
                                <small class="text-muted">This is the name of your company or organization.</small>
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger">
                                    @errorMessage
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <button type="button" class="btn btn-link" @onclick="@(() => Navigation.NavigateTo("/"))">
                                    Skip for now
                                </button>
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Create Organization
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private OrganizationModel model = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private bool hasOrganization;
    private string? errorMessage;
    private int redirectCountdown = 5;
    private System.Threading.Timer? redirectTimer;

    protected override async Task OnInitializedAsync()
    {
        await CheckOrganizationStatus();

        if (hasOrganization)
        {
            StartRedirectCountdown();
        }
    }

    private void StartRedirectCountdown()
    {
        redirectTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (redirectCountdown > 0)
                {
                    redirectCountdown--;
                    StateHasChanged();
                }
                else
                {
                    redirectTimer?.Dispose();
                    Navigation.NavigateTo("/jobs", forceLoad: true);
                }
            });
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        redirectTimer?.Dispose();
    }

    private async Task CheckOrganizationStatus()
    {
        try
        {
            var userInfo = await AuthApi.GetCurrentUserAsync();
            hasOrganization = !string.IsNullOrEmpty(userInfo?.OrganizationId);
        }
        catch
        {
            // User doesn't have organization
            hasOrganization = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var response = await ApiClient.PostAsJsonAsync("/api/organizations/create", new
            {
                name = model.OrganizationName
            });

            if (response.IsSuccessStatusCode)
            {
                // Redirect to jobs page
                Navigation.NavigateTo("/jobs", forceLoad: true);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to create organization: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class OrganizationModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Organization name is required")]
        [System.ComponentModel.DataAnnotations.StringLength(200, MinimumLength = 2, ErrorMessage = "Organization name must be between 2 and 200 characters")]
        public string OrganizationName { get; set; } = "";
    }
}
